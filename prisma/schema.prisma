datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum Instrument {
  PIANO
  BASS
  DRUMS
  GUITAR
}

enum Difficulty {
  BASIC
  INTERMEDIATE
  ADVANCED
}

enum Level {
  BASIC
  INTERMEDIATE
  ADVANCED
}

enum GoalType {
  DAILY
  WEEKLY
}

enum ExerciseStatus {
  NOT_STARTED
  IN_PROGRESS
  MASTERED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  plan          Plan      @default(FREE)
  
  // Relaciones existentes Next-Auth y Lyrics
  songs         Song[]
  accounts      Account[]
  sessions      Session[]
  
  // Nuevos campos del backend antiguo
  instruments   Instrument[]
  currentLevel  Level       @default(BASIC)
  books         Book[]
  practiceSessions PracticeSession[]
  goals         Goal[]
  levelHistory  LevelHistory[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Song {
  id            String    @id @default(cuid())
  title         String
  artist        String?
  key           String    // Tonalidad original (C, D, E, etc)
  timeSignature String    @default("4/4") // Compás (4/4, 3/4, 6/8, etc)
  tempo         Int       @default(120) // Tempo en BPM
  content       String    @db.Text // Letras con acordes
  lyrics        String    @db.Text // Solo letras (para búsqueda)
  chords        String    @db.Text // JSON string con acordes
  tags          String[]  @default([])
  isFavorite    Boolean   @default(false)
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions      Version[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([title])
  @@index([key])
}

model Version {
  id        String   @id @default(cuid())
  songId    String
  song      Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  key       String
  createdAt DateTime @default(now())

  @@index([songId])
}

// ----------------------------------------------------
// MODELOS IMPORTADOS DEL ANTIGUO BACKEND EXPRESS
// ----------------------------------------------------

model Book {
  id            String      @id @default(uuid())
  name          String
  instrument    Instrument
  description   String      @default("")
  fileUrl       String      // S3 URL or local path
  fileKey       String      // S3 key for deletion
  userId        String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises     Exercise[]
  translations  BookTranslation[]
  
  @@index([userId])
  @@index([instrument])
}

model BookTranslation {
  id                String      @id @default(uuid())
  bookId            String
  language          String      // Código ISO (es, en, fr, etc.)
  translatedContent String      @db.Text
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  
  book              Book        @relation(fields: [bookId], references: [id], onDelete: Cascade)
  
  @@unique([bookId, language])
  @@index([bookId])
  @@index([language])
}

model Exercise {
  id            String      @id @default(uuid())
  name          String
  description   String      @default("")
  bookId        String
  pages         String      // "1-5" or "10, 12, 15"
  difficulty    Difficulty
  notes         String      @default("")
  category      String?     // Categoría del ejercicio (para batería: RUDIMENTS, INDEPENDENCE, etc.)
  targetTempo   Int?        // BPM objetivo para dominar el ejercicio
  minMasteryTime Int        @default(300) // Tiempo mínimo en segundos para considerar dominio (default 5 min)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  book          Book        @relation(fields: [bookId], references: [id], onDelete: Cascade)
  sessionExercises SessionExercise[]
  progress      ExerciseProgress[]
  
  @@index([bookId])
  @@index([difficulty])
  @@index([category])
}

// Renombrado de 'Session' a 'PracticeSession' para no interferir con Next-Auth 'Session'
model PracticeSession {
  id              String      @id @default(uuid())
  userId          String
  date            DateTime
  durationMinutes Int
  notes           String      @default("")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises       SessionExercise[]
  
  @@index([userId])
  @@index([date])
}

model SessionExercise {
  id              String      @id @default(uuid())
  practiceSessionId String
  exerciseId      String
  durationMinutes Int
  tempo           Int?        // BPM usado en esta sesión
  
  practiceSession PracticeSession @relation(fields: [practiceSessionId], references: [id], onDelete: Cascade)
  exercise        Exercise        @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  
  @@unique([practiceSessionId, exerciseId])
  @@index([practiceSessionId])
  @@index([exerciseId])
}

model Goal {
  id              String      @id @default(uuid())
  userId          String
  type            GoalType
  targetMinutes   Int
  startDate       DateTime
  active          Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([active])
}

model LevelHistory {
  id              String      @id @default(uuid())
  userId          String
  previousLevel   Level
  newLevel        Level
  achievedAt      DateTime    @default(now())
  totalHours      Float
  consistency     Float       // percentage
  exerciseVariety Int
  
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([achievedAt])
}

model ExerciseProgress {
  id                String          @id @default(uuid())
  userId            String
  exerciseId        String
  status            ExerciseStatus  @default(NOT_STARTED)
  currentTempo      Int?            // BPM actual alcanzado
  totalPracticeTime Int             @default(0) // Tiempo total practicado en segundos
  masteryTime       Int             @default(0) // Tiempo practicado al tempo objetivo en segundos
  lastPracticedAt   DateTime?
  masteredAt        DateTime?       // Fecha cuando se dominó el ejercicio
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  
  exercise          Exercise        @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  
  @@unique([userId, exerciseId])
  @@index([userId])
  @@index([exerciseId])
  @@index([status])
}
